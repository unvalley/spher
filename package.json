{
  "name": "spher",
  "version": "0.1.0",
  "description": "Canvas-first sphere layout engine.",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "pnpm lint && pnpm typecheck && pnpm test && pnpm test:browser && pnpm build && pnpm check:size",
    "check:size": "node scripts/check-package-size.mjs",
    "check:write": "biome check --write .",
    "clean": "rm -rf dist",
    "lint": "biome check .",
    "prepack": "pnpm run clean && pnpm run build",
    "test": "vitest run --config vitest.config.ts",
    "test:browser": "vitest run --config vitest.browser.config.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./core": {
      "types": "./dist/core/index.d.ts",
      "import": "./dist/core/index.js"
    },
    "./canvas": {
      "types": "./dist/canvas/index.d.ts",
      "import": "./dist/canvas/index.js"
    },
    "./react": {
      "types": "./dist/react/index.d.ts",
      "import": "./dist/react/index.js"
    }
  },
  "peerDependencies": {
    "react": ">=18"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  },
  "keywords": [
    "sphere",
    "spherical",
    "canvas",
    "layout",
    "3d",
    "interactive"
  ],
  "homepage": "https://github.com/unvalley/spher#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/unvalley/spher.git"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.13",
    "@types/react": "^19.2.7",
    "@vitest/browser-playwright": "^4.1.5",
    "playwright": "^1.59.1",
    "react": "^19.2.4",
    "tsdown": "^0.21.10",
    "typescript": "^5.9.3",
    "vitest": "^4.1.5"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  },
  "packageManager": "pnpm@10.33.0+sha512.10568bb4a6afb58c9eb3630da90cc9516417abebd3fabbe6739f0ae795728da1491e9db5a544c76ad8eb7570f5c4bb3d6c637b2cb41bfdcdb47fa823c8649319"
}
