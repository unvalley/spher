{
  "name": "spher",
  "version": "0.1.1",
  "description": "Canvas-first sphere layout engine.",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "pnpm lint && pnpm typecheck && pnpm test && pnpm test:browser && pnpm build && pnpm check:size",
    "check:size": "node scripts/check-package-size.mjs",
    "check:write": "biome check --write .",
    "clean": "rm -rf dist",
    "lint": "biome check .",
    "prepack": "pnpm clean && pnpm build",
    "test": "vitest run --config vitest.config.ts",
    "test:browser": "vitest run --config vitest.browser.config.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./react": {
      "types": "./dist/react/index.d.ts",
      "import": "./dist/react/index.js"
    }
  },
  "peerDependencies": {
    "react": ">=18"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  },
  "keywords": [
    "sphere",
    "spherical",
    "canvas",
    "layout",
    "3d",
    "interactive"
  ],
  "homepage": "https://github.com/unvalley/spher#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/unvalley/spher.git"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.13",
    "@types/react": "^19.2.7",
    "@vitest/browser-playwright": "^4.1.5",
    "playwright": "^1.59.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tsdown": "^0.21.10",
    "typescript": "^5.9.3",
    "vitest": "^4.1.5"
  },
  "packageManager": "pnpm@10.33.0"
}
